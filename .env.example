# ============== Gemini (otak AI) ==============
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_THINKING_LEVEL=low

# ============== Evolution API (WhatsApp) ==============
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ============== Database ==============
# Lokal: SQLite (zero setup). Production: ganti ke Postgres, contoh:
# postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///clinic.db

# ============== Persona AI ==============
AI_NAME=Gita
COMPANY_NAME=Glowria Aesthetic Clinic

# ============== Tuning ==============
BUFFER_SECONDS=8
MEMORY_WINDOW=20

# ============== Dashboard ==============
DASHBOARD_API_KEY=ganti-dengan-string-acak-panjang

# ============== Cloudflare R2 (penyimpanan gambar, OPSIONAL) ==============
# Isi KELIMA nilai untuk mengaktifkan R2. Kalau ada satu saja yang kosong,
# gambar otomatis disimpan ke folder media/ lokal (fallback, tidak error).
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nama-bucket
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
